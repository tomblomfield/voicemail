OPENAI_API_KEY=sk-...

# Required only for Gemini voice models.
GEMINI_API_KEY=

# Google OAuth2 - https://console.cloud.google.com/apis/credentials
# Enable both Gmail API and Google Calendar API for this client
# Create OAuth 2.0 Client ID (Web application type)
# Add your redirect URI as an authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Used to encrypt OAuth tokens stored in cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional: outbound email footer link. If unset, uses the hardcoded production URL.
VOICEMAIL_SITE_URL=

# Postgres connection string. On Railway this is set automatically via service reference.
# For local dev, use the public Railway URL or a local Postgres.
DATABASE_URL=

# Browser Use Cloud — enables browser-based unsubscribe for emails without one-click support.
# Get your API key at https://cloud.browser-use.com/settings?tab=api-keys&new=1
BROWSER_USE_API_KEY=
